/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self' mailto:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; connect-src 'self'; font-src 'self' data:; frame-ancestors 'none'; manifest-src 'self'; upgrade-insecure-requests; block-all-mixed-content
