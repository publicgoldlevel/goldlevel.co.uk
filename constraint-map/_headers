/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; manifest-src 'self'; connect-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), autoplay=(), fullscreen=(self)
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cache-Control: no-store

/assets/*
  Cache-Control: public, max-age=86400

/templates/*
  Content-Type: text/markdown; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: no-store

/logs/*
  Content-Type: text/csv; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: no-store
